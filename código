import pandas as pd
import os
from datetime import datetime
from openpyxl import load_workbook
from openpyxl.styles import Font, PatternFill, Alignment

# CAMINHO DA PASTA
pasta = "/Users/sachaclael/Library/CloudStorage/OneDrive-BibliotecasCompartilhadas-MinistériodaSaúde/Equipe CGSPD - Planilhas de Escalonamento (1)"

# Nome EXATO da aba
sheet_name = "Plano de Ação_consolidado"

# Lista para armazenar os DataFrames
dfs = []

# LEITURA DOS ARQUIVOS
for arquivo in os.listdir(pasta):

    # ignora arquivos temporários e não Excel
    if not arquivo.endswith(".xlsx") or arquivo.startswith("~$"):
        continue

    caminho_arquivo = os.path.join(pasta, arquivo)
    print(f"Lendo: {arquivo}")

    try:
        # leitura da planilha
        df = pd.read_excel(
            caminho_arquivo,
            sheet_name=sheet_name,
            header=2,  # linha 3 como cabeçalho
            engine="openpyxl"
        )

        # remove linhas totalmente vazias
        df = df.dropna(how='all')

        # remove colunas completamente vazias
        df = df.dropna(axis=1, how='all')

        # remove possíveis espaços extras nos nomes das colunas
        df.columns = df.columns.str.strip()

        # adiciona coluna com origem (estado)
        df["ARQUIVO_ORIGEM"] = arquivo.replace(".xlsx", "")

        # adiciona apenas se tiver dados
        if not df.empty:
            dfs.append(df)

    except Exception as e:
        print(f"Erro ao processar {arquivo}: {e}")

# VALIDAÇÃO
if not dfs:
    raise Exception("Nenhum dado foi carregado. Verifique os arquivos e o nome da aba.")

# CONSOLIDAÇÃO
df_final = pd.concat(dfs, ignore_index=True)

# remove duplicados
df_final = df_final.drop_duplicates()

# reseta índice
df_final = df_final.reset_index(drop=True)

# NOME DO ARQUIVO
data_hoje = datetime.now().strftime("%Y - %m - %d")
nome_arquivo = f"{data_hoje} - Atualizado.xlsx"

caminho_saida = os.path.join(pasta, nome_arquivo)

# EXCLUIR PLANILHA ANTIGA
for arquivo in os.listdir(pasta):
    if arquivo.endswith(" - Atualizado.xlsx") and arquivo != nome_arquivo:
        caminho_antigo = os.path.join(pasta, arquivo)
        try:
            os.remove(caminho_antigo)
            print(f"Planilha antiga removida: {arquivo}")
        except Exception as e:
            print(f"Não foi possível remover {arquivo}: {e}")

# Se já existir o arquivo do dia, remove antes de criar o novo
if os.path.exists(caminho_saida):
    try:
        os.remove(caminho_saida)
        print(f"Arquivo anterior do dia removido: {nome_arquivo}")
    except Exception as e:
        print(f"Não foi possível remover o arquivo atual existente: {e}")

# Nova ABA: RESUMO ANALÍTICO

# Nome exato das colunas
col_uf = "UF"
col_objeto = "OBJETO"
col_valor = "VALOR  (MÊS / PARCELA ÚNICA)"

# Validação das colunas
for col in [col_uf, col_objeto, col_valor]:
    if col not in df_final.columns:
        raise Exception(f"A coluna '{col}' não foi encontrada no consolidado.")

# Cria cópia para tratamento
df_resumo = df_final.copy()

# Trata a coluna de valor para número
df_resumo[col_valor] = (
    df_resumo[col_valor]
    .astype(str)
    .str.replace("R$", "", regex=False)
    .str.replace(".", "", regex=False)
    .str.replace(",", ".", regex=False)
    .str.replace("-", "0", regex=False)
    .str.replace(" ", "", regex=False)
)

df_resumo[col_valor] = pd.to_numeric(df_resumo[col_valor], errors="coerce").fillna(0)

# Padroniza UF e OBJETO
df_resumo[col_uf] = df_resumo[col_uf].astype(str).str.strip()
df_resumo[col_objeto] = df_resumo[col_objeto].astype(str).str.strip()

# RESUMO BRASIL
resumo_brasil = (
    df_resumo.groupby(col_objeto, dropna=False)
    .agg(
        **{
            "Contagem de OBJETO": (col_objeto, "size"),
            "Soma de VALOR  (MÊS / PARCELA ÚNICA)": (col_valor, "sum")
        }
    )
    .reset_index()
)

resumo_brasil.insert(0, "UF", "BRASIL")
resumo_brasil = resumo_brasil.sort_values(by="Contagem de OBJETO", ascending=False)

# Total Brasil
total_brasil = pd.DataFrame([{
    "UF": "BRASIL",
    "OBJETO": "TOTAL BRASIL",
    "Contagem de OBJETO": resumo_brasil["Contagem de OBJETO"].sum(),
    "Soma de VALOR  (MÊS / PARCELA ÚNICA)": resumo_brasil["Soma de VALOR  (MÊS / PARCELA ÚNICA)"].sum()
}])

resumo_brasil = pd.concat([resumo_brasil, total_brasil], ignore_index=True)

# RESUMO POR UF COM TOTAL POR UF
ufs_ordenadas = sorted(df_resumo[col_uf].dropna().unique())

lista_ufs = []

for uf in ufs_ordenadas:
    df_uf = df_resumo[df_resumo[col_uf] == uf]

    resumo_uf = (
        df_uf.groupby(col_objeto, dropna=False)
        .agg(
            **{
                "Contagem de OBJETO": (col_objeto, "size"),
                "Soma de VALOR  (MÊS / PARCELA ÚNICA)": (col_valor, "sum")
            }
        )
        .reset_index()
    )

    resumo_uf.insert(0, "UF", uf)
    resumo_uf = resumo_uf.sort_values(by="Contagem de OBJETO", ascending=False)

    total_uf = pd.DataFrame([{
        "UF": uf,
        "OBJETO": f"TOTAL {uf}",
        "Contagem de OBJETO": resumo_uf["Contagem de OBJETO"].sum(),
        "Soma de VALOR  (MÊS / PARCELA ÚNICA)": resumo_uf["Soma de VALOR  (MÊS / PARCELA ÚNICA)"].sum()
    }])

    resumo_uf = pd.concat([resumo_uf, total_uf], ignore_index=True)
    lista_ufs.append(resumo_uf)

resumo_estados = pd.concat(lista_ufs, ignore_index=True)

# JUNTA TUDO EM UMA ÚNICA ABA
df_pivot_final = pd.concat([resumo_brasil, resumo_estados], ignore_index=True)

# Total Geral
total_geral = pd.DataFrame([{
    "UF": "TOTAL GERAL",
    "OBJETO": "",
    "Contagem de OBJETO": df_resumo.shape[0],
    "Soma de VALOR  (MÊS / PARCELA ÚNICA)": df_resumo[col_valor].sum()
}])

df_pivot_final = pd.concat([df_pivot_final, total_geral], ignore_index=True)

# SALVAR NO EXCEL
with pd.ExcelWriter(caminho_saida, engine="openpyxl") as writer:
    df_final.to_excel(writer, sheet_name="BASE_CONSOLIDADA", index=False)
    df_pivot_final.to_excel(writer, sheet_name="RESUMO_OBJETO_UF", index=False)

# FORMATAÇÃO EXCEL
wb = load_workbook(caminho_saida)

# Cores e estilos
cor_fundo = PatternFill(start_color="BDD7EE", end_color="BDD7EE", fill_type="solid")  # azul claro
fonte = Font(color="000000", bold=True)  # preto + negrito
alinhamento_cabecalho = Alignment(horizontal="center", vertical="center")

cor_total = PatternFill(start_color="D9EAD3", end_color="D9EAD3", fill_type="solid")  # verde claro
cor_total_geral = PatternFill(start_color="FFF2CC", end_color="FFF2CC", fill_type="solid")  # amarelo claro

def formatar_aba(ws, congelar="A2"):
    # filtro automático
    ws.auto_filter.ref = ws.dimensions
    ws.freeze_panes = congelar

    # cabeçalho
    for cell in ws[1]:
        cell.fill = cor_fundo
        cell.font = fonte
        cell.alignment = alinhamento_cabecalho

    # largura automática das colunas
    for col in ws.columns:
        max_length = 0
        col_letter = col[0].column_letter

        for cell in col:
            try:
                if cell.value is not None:
                    comprimento = len(str(cell.value))
                    if comprimento > max_length:
                        max_length = comprimento
            except:
                pass

        largura_ajustada = min(max_length + 2, 60)
        ws.column_dimensions[col_letter].width = largura_ajustada

# Formata todas as abas
for sheet in wb.sheetnames:
    ws = wb[sheet]
    formatar_aba(ws)

# FORMATAÇÃO ESPECÍFICA DA ABA RESUMO
ws_resumo = wb["RESUMO_OBJETO_UF"]

# Formata moeda e destaca totais
for row in range(2, ws_resumo.max_row + 1):
    valor_uf = str(ws_resumo.cell(row=row, column=1).value)
    valor_objeto = str(ws_resumo.cell(row=row, column=2).value)

    # moeda
    for col in range(1, ws_resumo.max_column + 1):
        cabecalho = str(ws_resumo.cell(row=1, column=col).value)
        cell = ws_resumo.cell(row=row, column=col)

        if "Soma de VALOR" in cabecalho:
            cell.number_format = 'R$ #,##0.00'

    # total por UF / BRASIL
    if valor_objeto.startswith("TOTAL "):
        for col in range(1, ws_resumo.max_column + 1):
            ws_resumo.cell(row=row, column=col).font = Font(color="000000", bold=True)
            ws_resumo.cell(row=row, column=col).fill = cor_total

    # total geral final
    if valor_uf == "TOTAL GERAL":
        for col in range(1, ws_resumo.max_column + 1):
            ws_resumo.cell(row=row, column=col).font = Font(color="000000", bold=True)
            ws_resumo.cell(row=row, column=col).fill = cor_total_geral

wb.save(caminho_saida)

print("\n✅ CONSOLIDAÇÃO FINALIZADA COM SUCESSO:")
print(caminho_saida)
